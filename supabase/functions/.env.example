# =============================================================================
# Supabase Edge Functions Environment Configuration
# =============================================================================
# This file contains example environment variables required for Edge Functions.
# Copy this file to .env and update with your actual values.
# IMPORTANT: Never commit the actual .env file to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# OpenAI Configuration (Required)
# -----------------------------------------------------------------------------
# Your OpenAI API key for document generation
# Obtain from: https://platform.openai.com/api-keys
# Security: Keep this secret! Never commit to version control
OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# -----------------------------------------------------------------------------
# Supabase Configuration (Required)
# -----------------------------------------------------------------------------
# Your Supabase project URL
# Find in: Supabase Dashboard > Project Settings > API
# Example: https://abcdefghijklmnop.supabase.co
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Service Role Key (for server-side operations)
# Find in: Supabase Dashboard > Project Settings > API > service_role key
# Security: This key bypasses Row Level Security (RLS) policies
# Use case: Accessing platform_settings table and other admin operations
# IMPORTANT: Keep this secret! Never expose in client-side code
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# -----------------------------------------------------------------------------
# Optional Configuration
# -----------------------------------------------------------------------------
# These are typically loaded from the platform_settings database table
# You can override them here for testing/development purposes

# Default OpenAI model to use
# Options: gpt-4o, gpt-4o-mini, gpt-4-turbo, gpt-3.5-turbo
# DEFAULT_OPENAI_MODEL=gpt-4o

# Default temperature for AI responses (0.0 to 2.0)
# Lower = more focused/deterministic, Higher = more creative/random
# DEFAULT_TEMPERATURE=0.7

# Default token limit for responses
# DEFAULT_TOKEN_LIMIT=4096

# -----------------------------------------------------------------------------
# Microsoft Calendar Integration (Required for Outlook 365)
# -----------------------------------------------------------------------------
# Documentation: docs/calendar-integration.md
# Azure Portal: https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps
#
# Prerequisites:
# 1. Register an application in Azure AD
# 2. Configure API permissions (Delegated): Calendars.Read, Calendars.ReadWrite, User.Read, offline_access
# 3. Add redirect URI to the app registration
# 4. Generate a client secret
# 5. Grant admin consent if required by tenant

# Microsoft Azure AD Application Client ID (Required)
# How to obtain: Azure Portal > App Registrations > Your App > Application (client) ID
# Format: UUID (e.g., 00000000-0000-0000-0000-000000000000)
MS_OAUTH_CLIENT_ID=00000000-0000-0000-0000-000000000000

# Microsoft Azure AD Application Client Secret (Required)
# How to obtain: Azure Portal > App Registrations > Your App > Certificates & secrets > New client secret
# Security: Keep this secret! Never commit to version control
MS_OAUTH_CLIENT_SECRET=your-client-secret-here

# OAuth Callback URL (Required)
# Format: https://[project-ref].supabase.co/functions/v1/ms-oauth-callback
# IMPORTANT: Must match EXACTLY what is configured in Azure AD > App Registrations > Your App > Authentication > Redirect URIs
MS_OAUTH_REDIRECT_URI=https://your-project-id.supabase.co/functions/v1/ms-oauth-callback

# -----------------------------------------------------------------------------
# Token Encryption (Required for Calendar Integration)
# -----------------------------------------------------------------------------
# These keys are used to securely encrypt OAuth tokens before database storage
# and to sign OAuth state parameters to prevent CSRF attacks.

# AES-256-GCM Encryption Key for Token Storage (Required)
# Description: 32-byte hex-encoded key (64 hex characters)
# How to generate: openssl rand -hex 32
# Security: Keep this secret! Never commit to version control
# Used for: Encrypting refresh tokens before storing in database
ENCRYPTION_KEY=

# HMAC Signing Key for OAuth State Parameter (Required)
# Description: 32-byte hex-encoded key (64 hex characters)
# How to generate: openssl rand -hex 32
# Security: Keep this secret! Never commit to version control
# Used for: Signing OAuth state to prevent CSRF attacks
STATE_SIGNING_KEY=

# -----------------------------------------------------------------------------
# Recall.ai Integration (Required if using Recall.ai for calendar webhooks)
# -----------------------------------------------------------------------------
# Documentation: https://recallai.readme.io/

# Recall.ai API Key (Required for Recall.ai integration)
# How to obtain: Recall.ai Dashboard > API Keys
# Security: Keep this secret! Never commit to version control
RECALL_API_KEY=your-recall-api-key-here

# Recall.ai API Region (Optional)
# Options: us, eu
# Default: us (if not specified)
RECALL_REGION=us

# -----------------------------------------------------------------------------
# Frontend Configuration (Required for OAuth callbacks)
# -----------------------------------------------------------------------------
# The URL of your frontend application
# Used for OAuth callback redirects
FRONTEND_URL=https://your-frontend-domain.com

# -----------------------------------------------------------------------------
# DR Media Tools Integration (Required for meeting recording and transcription)
# -----------------------------------------------------------------------------
# Documentation: docs/integrations/dr-media-tools-integration.md
#
# Prerequisites:
# 1. Generate MEDIA_TOOLS_JWT_SECRET: openssl rand -hex 32
# 2. Generate MEDIA_CALLBACK_SECRET: openssl rand -hex 32
# 3. Configure secrets via: supabase secrets set MEDIA_TOOLS_JWT_SECRET=<value>
# 4. Deploy Edge Functions: supabase functions deploy create-media-meeting
#                           supabase functions deploy media-meeting-callback

# JWT secret for signing requests to DR Media Tools API (Required)
# Algorithm: HS256 — short-lived token (5 minutes)
# How to generate: openssl rand -hex 32
# Security: Keep this secret! Never commit to version control
MEDIA_TOOLS_JWT_SECRET=your-media-tools-jwt-secret-here

# Callback secret for authenticating webhook requests from DR Media Tools (Required)
# Sent as header: X-Callback-Secret on every callback request
# How to generate: openssl rand -hex 32
# Security: Keep this secret! Use a different value from MEDIA_TOOLS_JWT_SECRET
MEDIA_CALLBACK_SECRET=your-media-callback-secret-here

# DR Media Tools API base URL (Optional)
# Default: https://media.digitalrepublic.dev.br
# Override only if using a staging or custom environment
# MEDIA_TOOLS_API_URL=https://media.digitalrepublic.dev.br
